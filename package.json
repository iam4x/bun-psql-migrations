{
  "name": "bun-psql-migrations",
  "version": "1.0.2",
  "description": "Lightweight PostgreSQL migration tool for Bun - Simple CLI and programmatic API for database schema migrations",
  "author": "iam4x",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iam4x/bun-psql-migrations"
  },
  "homepage": "https://github.com/iam4x/bun-psql-migrations#readme",
  "bugs": {
    "url": "https://github.com/iam4x/bun-psql-migrations/issues"
  },
  "keywords": [
    "bun",
    "postgresql",
    "postgres",
    "psql",
    "pg",
    "migrations",
    "migrate",
    "migrator",
    "database",
    "schema",
    "sql",
    "cli",
    "db",
    "rollback",
    "up",
    "down"
  ],
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "bun-psql-migrations": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts src/cli.ts --outdir dist --target bun --external pino --external pino-pretty && chmod +x dist/cli.js && bun run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "test": "bun test src/index.test.ts",
    "test:integration": "bun test src/index.integration.test.ts --timeout 60000",
    "test:all": "bun test --timeout 60000",
    "dev": "bun run --watch src/cli.ts",
    "lint": "bun run lint:eslint && bun run lint:tsc",
    "lint:eslint": "eslint src",
    "lint:tsc": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "latest",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "10.1.1",
    "eslint-import-resolver-typescript": "4.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.54.0"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3"
  }
}
